# DIVEXPLORE-3D Backend — Environment Template
# Salin file ini menjadi .env lalu isi nilainya
# JANGAN commit file .env ke GitHub!

# --- Database (PostgreSQL) ---
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=divexplore_db

# --- Server ---
PORT=5000
NODE_ENV=development

# --- JWT Authentication ---
JWT_SECRET=ganti_dengan_string_random_minimal_32_karakter
JWT_EXPIRES_IN=7d

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- AWS S3 (Cloud Storage) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=divexplore-bucket

# --- AWS SES (Email Service) ---
AWS_SES_FROM_EMAIL=no-reply@divexplore.id

# --- Midtrans (Payment Gateway) ---
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
